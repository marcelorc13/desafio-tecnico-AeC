<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LocaMap</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand:    '#0369A1',
                        'brand-dark': '#025484',
                        'brand-light': '#E0F2FE',
                        navy:     '#0F172A',
                        slate:    '#334155',
                        muted:    '#64748B',
                        subtle:   '#94A3B8',
                        border:   '#E2E8F0',
                        'border-dark': '#CBD5E1',
                        surface:  '#F8FAFC',
                        white:    '#FFFFFF',
                        success:  '#16A34A',
                        danger:   '#DC2626',
                        warning:  '#D97706',
                    },
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    fontSize: {
                        '2xs': ['0.65rem', { lineHeight: '1rem' }],
                    },
                    boxShadow: {
                        card:  '0 1px 3px rgba(15,23,42,.06), 0 1px 2px rgba(15,23,42,.04)',
                        panel: '0 4px 16px rgba(15,23,42,.08)',
                        focus: '0 0 0 3px rgba(3,105,161,.18)',
                    },
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-surface text-navy font-sans antialiased min-h-screen">

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <header class="flex items-center justify-between h-16 border-b border-border">
            <a asp-action="Index" asp-controller="Address" class="flex items-center gap-2.5 no-underline group">
                @if (System.IO.File.Exists(System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "images", "logo.png")))
                {
                    <img src="~/images/logo.png" alt="Logo" class="h-8 w-auto object-contain" />
                }
                else if (System.IO.File.Exists(System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "images", "logo.svg")))
                {
                    <img src="~/images/logo.svg" alt="Logo" class="h-8 w-auto object-contain" />
                }
                else
                {
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" class="flex-shrink-0">
                        <rect width="28" height="28" rx="6" fill="#0369A1"/>
                        <path d="M14 5C10.134 5 7 8.134 7 12c0 5.25 7 14 7 14s7-8.75 7-14c0-3.866-3.134-7-7-7zm0 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" fill="white"/>
                    </svg>
                }
            </a>

            <nav class="flex items-center gap-1">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="Index" asp-controller="Address"
                       class="text-sm font-medium text-slate hover:text-navy hover:bg-white px-3 py-1.5 rounded-md transition-colors duration-150 no-underline cursor-pointer">
                        Endereços
                    </a>
                    <a asp-action="Index" asp-controller="Profile"
                       class="text-sm font-medium text-slate hover:text-navy hover:bg-white px-3 py-1.5 rounded-md transition-colors duration-150 no-underline cursor-pointer">
                        Perfil
                    </a>
<form asp-action="Logout" asp-controller="Auth" method="post" class="inline">
                        <button type="submit" class="text-sm font-medium text-muted hover:text-danger hover:bg-red-50 px-3 py-1.5 rounded-md transition-colors duration-150 bg-transparent border-0 cursor-pointer">
                            Sair
                        </button>
                    </form>
                }
                else
                {
                    <a asp-action="Login" asp-controller="Auth"
                       class="text-sm font-medium text-slate hover:text-navy px-3 py-1.5 rounded-md transition-colors duration-150 no-underline cursor-pointer">
                        Entrar
                    </a>
                    <a asp-action="Register" asp-controller="Auth"
                       class="text-sm font-semibold text-white bg-brand hover:bg-brand-dark px-4 py-1.5 rounded-md transition-colors duration-150 no-underline cursor-pointer shadow-sm">
                        Cadastrar
                    </a>
                }
            </nav>
        </header>

        <main role="main" class="py-8">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

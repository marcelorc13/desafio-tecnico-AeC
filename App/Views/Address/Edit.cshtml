@model App.Models.DTOs.AddressCreateDto
@{
    ViewData["Title"] = "Editar Endereço";
    var id = ViewContext.RouteData.Values["id"];
}

<div class="mb-6">
    <nav class="flex items-center gap-1.5 text-xs text-muted mb-3">
        <a asp-action="Index" class="hover:text-slate no-underline cursor-pointer transition-colors duration-150">Endereços</a>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 2.5L7.5 6l-3 3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        <span class="text-slate font-medium">Editar</span>
    </nav>
    <h1 class="text-xl font-bold text-navy m-0">Editar Endereço</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6 items-start">

    <div class="bg-white border border-border rounded-xl shadow-card">
        <div class="px-6 py-4 border-b border-border">
            <p class="text-sm font-medium text-slate m-0">Informações do endereço</p>
        </div>
        <div class="px-6 py-5">
            <form asp-action="Update" asp-controller="Address" asp-route-id="@id" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-danger text-sm rounded-md px-3 py-2 validation-summary-errors"></div>

                <div>
                    <label asp-for="Name" class="block text-xs font-semibold text-slate mb-1.5">Apelido</label>
                    <input asp-for="Name" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div>
                    <label asp-for="CEP" class="block text-xs font-semibold text-slate mb-1.5">CEP</label>
                    <div class="relative">
                        <input asp-for="CEP" id="cep-input" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" maxlength="8" />
                        <div id="cep-loading" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
                            <svg class="animate-spin" width="14" height="14" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="12" r="10" stroke="#CBD5E1" stroke-width="3"/>
                                <path d="M22 12a10 10 0 0 0-10-10" stroke="#0369A1" stroke-width="3" stroke-linecap="round"/>
                            </svg>
                        </div>
                    </div>
                    <span asp-validation-for="CEP" class="field-validation-error"></span>
                </div>

                <div>
                    <label asp-for="PublicPlace" class="block text-xs font-semibold text-slate mb-1.5">Logradouro</label>
                    <input asp-for="PublicPlace" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" />
                    <span asp-validation-for="PublicPlace" class="field-validation-error"></span>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label asp-for="Number" class="block text-xs font-semibold text-slate mb-1.5">Número</label>
                        <input asp-for="Number" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" />
                        <span asp-validation-for="Number" class="field-validation-error"></span>
                    </div>
                    <div>
                        <label asp-for="Complement" class="block text-xs font-semibold text-slate mb-1.5">Complemento <span class="text-subtle font-normal">(opcional)</span></label>
                        <input asp-for="Complement" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" />
                        <span asp-validation-for="Complement" class="field-validation-error"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="District" class="block text-xs font-semibold text-slate mb-1.5">Bairro</label>
                    <input asp-for="District" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" />
                    <span asp-validation-for="District" class="field-validation-error"></span>
                </div>

                <div class="grid grid-cols-[1fr_72px] gap-3">
                    <div>
                        <label asp-for="City" class="block text-xs font-semibold text-slate mb-1.5">Cidade</label>
                        <input asp-for="City" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" />
                        <span asp-validation-for="City" class="field-validation-error"></span>
                    </div>
                    <div>
                        <label asp-for="FederalUnit" class="block text-xs font-semibold text-slate mb-1.5">UF</label>
                        <input asp-for="FederalUnit" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm text-center placeholder-subtle focus:border-brand transition-colors duration-150 uppercase" maxlength="2" />
                        <span asp-validation-for="FederalUnit" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="flex gap-2 pt-2 border-t border-border">
                    <button type="submit" class="inline-flex items-center text-sm font-semibold text-white bg-brand hover:bg-brand-dark px-5 py-2 rounded-md transition-colors duration-150 border-0 cursor-pointer">Salvar</button>
                    <a asp-action="Index" class="inline-flex items-center text-sm font-medium text-muted bg-surface border border-border hover:border-border-dark hover:text-slate px-5 py-2 rounded-md transition-colors duration-150 no-underline cursor-pointer">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="flex flex-col gap-4">
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
            <div class="flex items-center gap-2.5 mb-3">
                <div class="w-8 h-8 rounded-lg bg-warning flex items-center justify-center flex-shrink-0">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <p class="text-sm font-semibold text-warning m-0">Editando endereço</p>
            </div>
            <p class="text-xs text-slate leading-relaxed m-0">
                As alterações serão salvas imediatamente ao clicar em <strong>Salvar</strong>.
            </p>
        </div>

        <div class="bg-brand-light border border-blue-200 rounded-xl p-5">
            <div class="flex items-center gap-2.5 mb-3">
                <div class="w-8 h-8 rounded-lg bg-brand flex items-center justify-center flex-shrink-0">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M12 2C8.134 2 5 5.134 5 9c0 6.563 7 14 7 14s7-7.437 7-14c0-3.866-3.134-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" fill="white"/>
                    </svg>
                </div>
                <p class="text-sm font-semibold text-brand m-0">Preenchimento automático</p>
            </div>
            <p class="text-xs text-slate leading-relaxed m-0">
                Altere o CEP e clique fora do campo para buscar novamente o logradouro, bairro, cidade e UF.
            </p>
        </div>
    </div>

</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.getElementById('cep-input').addEventListener('blur', async function () {
            const cep = this.value.replace(/\D/g, '');
            if (cep.length !== 8) return;
            const loader = document.getElementById('cep-loading');
            loader.classList.remove('hidden');
            try {
                const res = await fetch(`/addresses/cep/${cep}`);
                if (!res.ok) return;
                const data = await res.json();
                document.getElementById('PublicPlace').value = data.logradouro ?? '';
                document.getElementById('District').value   = data.bairro     ?? '';
                document.getElementById('City').value       = data.localidade  ?? '';
                document.getElementById('FederalUnit').value= (data.uf ?? '').toUpperCase();
                document.getElementById('Complement').value = data.complemento ?? '';
            } catch {}
            finally { loader.classList.add('hidden'); }
        });
    </script>
}

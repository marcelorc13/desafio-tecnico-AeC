@model ChangePasswordDTO
@{
    ViewData["Title"] = "Alterar Senha";
}

<div class="mb-6">
    <nav class="flex items-center gap-1.5 text-xs text-muted mb-3">
        <a asp-action="Index" class="hover:text-slate no-underline cursor-pointer transition-colors duration-150">Perfil</a>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 2.5L7.5 6l-3 3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        <span class="text-slate font-medium">Alterar senha</span>
    </nav>
    <h1 class="text-xl font-bold text-navy m-0">Alterar Senha</h1>
</div>

<div class="bg-white border border-border rounded-xl shadow-card max-w-xl">
    <div class="px-6 py-4 border-b border-border">
        <p class="text-sm font-medium text-slate m-0">Nova senha</p>
    </div>
    <div class="px-6 py-5">
        <form asp-action="UpdatePassword" asp-controller="Profile" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-danger text-sm rounded-md px-3 py-2 validation-summary-errors"></div>

            <div>
                <label asp-for="CurrentPassword" class="block text-xs font-semibold text-slate mb-1.5">Senha atual</label>
                <input asp-for="CurrentPassword" type="password" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" autocomplete="current-password" />
                <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="NewPassword" class="block text-xs font-semibold text-slate mb-1.5">Nova senha</label>
                <input asp-for="NewPassword" type="password" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-xs font-semibold text-slate mb-1.5">Confirmar nova senha</label>
                <input asp-for="ConfirmPassword" type="password" class="w-full bg-surface border border-border text-navy rounded-md px-3 py-2.5 text-sm placeholder-subtle focus:border-brand transition-colors duration-150" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <div class="flex gap-2 pt-2 border-t border-border">
                <button type="submit" class="inline-flex items-center text-sm font-semibold text-white bg-brand hover:bg-brand-dark px-5 py-2 rounded-md transition-colors duration-150 border-0 cursor-pointer">Salvar</button>
                <a asp-action="Index" class="inline-flex items-center text-sm font-medium text-muted bg-surface border border-border hover:border-border-dark hover:text-slate px-5 py-2 rounded-md transition-colors duration-150 no-underline cursor-pointer">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

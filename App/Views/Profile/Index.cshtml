@model ProfileResponseDto
@{
    ViewData["Title"] = "Meu Perfil";
}

@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-success text-sm rounded-md px-4 py-3 mb-6 flex items-center gap-2">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" class="flex-shrink-0">
            <path d="M3 8l3.5 3.5L13 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        @TempData["Success"]
    </div>
}

<div class="bg-white border border-border rounded-xl shadow-card overflow-hidden">

    <div class="relative bg-gradient-to-br from-slate to-navy px-8 py-8 overflow-hidden">
        <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-white/5"></div>
        <div class="absolute -bottom-14 -left-8 w-64 h-64 rounded-full bg-white/5"></div>
        <div class="relative flex items-center gap-5">
            <div class="flex-shrink-0 flex items-center justify-center w-16 h-16 rounded-2xl bg-white/15 backdrop-blur-sm border border-white/20 text-2xl font-bold text-white select-none">
                @Model.Name.Substring(0, 1).ToUpper()
            </div>
            <div>
                <p class="text-white/60 text-xs font-semibold tracking-widest uppercase mb-0.5">Perfil</p>
                <h1 class="text-2xl font-bold text-white m-0 leading-tight">@Model.Name</h1>
                <p class="text-white/70 text-sm mt-0.5 m-0">@@@Model.Username</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-border border-b border-border">
        <div class="px-8 py-6">
            <p class="text-2xs font-semibold tracking-widest uppercase text-subtle mb-2">Nome completo</p>
            <p class="text-lg font-semibold text-navy m-0">@Model.Name</p>
        </div>
        <div class="px-8 py-6">
            <p class="text-2xs font-semibold tracking-widest uppercase text-subtle mb-2">Nome de usuário</p>
            <p class="text-lg font-semibold text-navy m-0">@@@Model.Username</p>
        </div>
    </div>

    <div class="px-8 py-5 bg-surface border-b border-border">
        <p class="text-2xs font-semibold tracking-widest uppercase text-subtle mb-3">Segurança</p>
        <div class="flex items-center gap-3 bg-white border border-border rounded-lg px-4 py-3">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-brand-light flex-shrink-0">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="text-brand">
                    <rect x="3" y="7" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                    <path d="M5.5 7V5a2.5 2.5 0 015 0v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-navy m-0">Senha</p>
                <p class="text-xs text-muted m-0">Última alteração não registrada</p>
            </div>
            <a asp-action="ChangePassword"
               class="inline-flex items-center gap-1.5 text-xs font-medium text-muted bg-surface border border-border hover:border-border-dark hover:text-slate px-3 py-1.5 rounded-md transition-colors duration-150 no-underline cursor-pointer flex-shrink-0">
                Alterar senha
            </a>
        </div>
    </div>

    <div class="px-8 py-5 flex flex-wrap gap-2">
        <a asp-action="Edit"
           class="inline-flex items-center gap-1.5 text-sm font-semibold text-white bg-brand hover:bg-brand-dark px-5 py-2.5 rounded-md transition-colors duration-150 no-underline cursor-pointer">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                <path d="M11.5 2.5a1.414 1.414 0 012 2L5 13H2v-3L11.5 2.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Editar perfil
        </a>
        <a asp-action="Index" asp-controller="Address"
           class="inline-flex items-center gap-1.5 text-sm font-medium text-muted bg-white border border-border hover:border-border-dark hover:text-slate px-5 py-2.5 rounded-md transition-colors duration-150 no-underline cursor-pointer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C8.134 2 5 5.134 5 9c0 6.5 7 15 7 15s7-8.5 7-15c0-3.866-3.134-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" fill="currentColor"/>
            </svg>
            Meus endereços
        </a>
    </div>
</div>

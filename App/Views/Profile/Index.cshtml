@model ProfileResponseDto
@{
    ViewData["Title"] = "Meu Perfil";
}

<div class="mb-6">
    <h1 class="text-xl font-bold text-navy m-0">Meu Perfil</h1>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-green-50 border border-green-200 text-success text-sm rounded-md px-3 py-2 mb-4">
        @TempData["Success"]
    </div>
}

<div class="bg-white border border-border rounded-xl shadow-card max-w-xl">
    <div class="px-6 py-4 border-b border-border">
        <p class="text-sm font-medium text-slate m-0">Informações da conta</p>
    </div>
    <div class="px-6 py-5 space-y-4">
        <div>
            <p class="text-xs font-semibold text-slate mb-1">Nome</p>
            <p class="text-sm text-navy">@Model.Name</p>
        </div>
        <div>
            <p class="text-xs font-semibold text-slate mb-1">Usuário</p>
            <p class="text-sm text-navy">@Model.Username</p>
        </div>
        <div class="flex gap-2 pt-2 border-t border-border">
            <a asp-action="Edit" class="inline-flex items-center text-sm font-semibold text-white bg-brand hover:bg-brand-dark px-5 py-2 rounded-md transition-colors duration-150 no-underline cursor-pointer">
                Editar perfil
            </a>
            <a asp-action="ChangePassword" class="inline-flex items-center text-sm font-medium text-muted bg-surface border border-border hover:border-border-dark hover:text-slate px-5 py-2 rounded-md transition-colors duration-150 no-underline cursor-pointer">
                Alterar senha
            </a>
        </div>
    </div>
</div>
